# Copy to .env and fill in. .env is gitignored — never commit real keys.
OPENROUTER_API_KEY=          # provider (organizer-supplied OpenRouter key)
HYDRA_API_KEY=               # HydraDB (episodic memory + bonus)
MODEL=meta-llama/llama-3.3-70b-instruct
# Optional — only used by the local-file memory fallback when HYDRA_API_KEY is unset:
# OPENAI_API_KEY=
